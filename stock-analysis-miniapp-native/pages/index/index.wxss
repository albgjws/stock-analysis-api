.page{min-height:100vh;background:linear-gradient(180deg,#e8f0fe 0%,#f0f2f5 40%,#f5f5f5 100%);padding-bottom:24px}
.header{padding:36px 20px 16px;text-align:center}
.header-icon{font-size:36px;display:block;margin-bottom:6px}
.header-title{font-size:20px;font-weight:700;color:#1a1a2e;letter-spacing:1px}
.header-sub{font-size:12px;color:#7a8ba8;margin-top:4px}

/* 搜索框 */
.search-box{padding:0 16px 16px}
.search-bar{
  display:flex;align-items:center;background:#fff;border-radius:12px;
  padding:0 14px;height:44px;box-shadow:0 2px 8px rgba(22,119,255,0.08);border:1px solid #e8edf5
}
.search-icon{font-size:15px;color:#7a8ba8;margin-right:8px}
.search-input{flex:1;font-size:14px;height:44px;color:#333;background:transparent;border:none;outline:none}
.search-input::placeholder{color:#b0b8c8}
.search-clear{padding:4px 8px;color:#b0b8c8;font-size:16px}

/* 搜索结果 */
.list-wrap{margin:0 12px;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.04);border:1px solid #f0f2f5}
.result-scroll{max-height:55vh}
.result-item{
  display:flex;justify-content:space-between;align-items:center;
  padding:14px 16px;border-bottom:1px solid #f5f6f8
}
.result-item:last-child{border:none}
.result-item:active{background:#f8f9fb}
.result-left{display:flex;align-items:baseline;gap:8px}
.result-name{font-weight:600;font-size:15px;color:#1a1a2e}
.result-code{font-size:12px;color:#8a9bb5}
.result-right{display:flex;align-items:center;gap:6px}
.result-arrow{color:#d0d8e0;font-size:18px;font-weight:300}
.loading{text-align:center;padding:30px;color:#8a9bb5;font-size:13px;background:#fff;border-radius:12px;margin:0 12px;box-shadow:0 2px 8px rgba(0,0,0,0.04);border:1px solid #f0f2f5}

/* 板块 */
.section{margin:0 12px;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.04);border:1px solid #f0f2f5}
.section-header{
  display:flex;justify-content:space-between;align-items:center;
  padding:14px 16px 8px;border-bottom:1px solid #f5f6f8
}
.section-title{font-size:13px;font-weight:500;color:#5a6a8a}
.section-action{font-size:12px;color:#8a9bb5;padding:4px 8px}

/* 引导页 */
.guide{display:flex;flex-direction:column;align-items:center;padding:24px 20px}
.guide-icon{font-size:40px;margin-bottom:8px}
.guide-title{font-size:18px;font-weight:700;color:#1a1a2e;margin-bottom:4px}
.guide-desc{font-size:13px;color:#7a8ba8;text-align:center;margin-bottom:24px;line-height:1.7;max-width:280px}
.feature-grid{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.feature-card{
  width:130px;padding:14px 10px;background:#fff;border-radius:10px;
  text-align:center;border:1px solid #e8edf5;box-shadow:0 1px 4px rgba(0,0,0,0.02)
}
.fc-icon{font-size:22px;display:block;margin-bottom:4px}
.fc-label{font-size:12px;font-weight:600;color:#333;display:block;margin-bottom:2px}
.fc-desc{font-size:10px;color:#8a9bb5}

/* 标签 */
.tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;line-height:1.5}
.tag-red{background:#fff2f0;color:#cf1322;border:1px solid #ffccc7}
.tag-green{background:#f6ffed;color:#3cb371;border:1px solid #b7eb8f}
.tag-blue{background:#e6f7ff;color:#1677ff;border:1px solid #91d5ff}
