page { background: #f5f5f5; font-size: 14px; color: #333; }
.price-up { color: #cf1322; }
.price-down { color: #3cb371; }
.card {
  background: #fff; border-radius: 8px; margin: 8px 12px; padding: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.card-title {
  font-size: 15px; font-weight: 600; margin-bottom: 8px;
  border-left: 3px solid #1677ff; padding-left: 8px;
}
.row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; }
.tag {
  display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; margin-left: 6px;
}
.tag-red { background: #fff2f0; color: #cf1322; border: 1px solid #ffccc7; }
.tag-green { background: #f6ffed; color: #3cb371; border: 1px solid #b7eb8f; }
.tag-yellow { background: #fffbe6; color: #d48806; border: 1px solid #ffe58f; }
.tag-blue { background: #e6f7ff; color: #1677ff; border: 1px solid #91d5ff; }
