    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "@vitejs/plugin-react": "^4.3.2",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
